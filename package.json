{
  "name": "taskmind",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n FRONT,BACK -c blue,green \"pnpm dev:fe\" \"pnpm dev:be\"",
    "dev:fe": "next dev FE/web-ui",
    "dev:be": "cd BE && python manage.py runserver 0.0.0.0:8000",
    "build": "next build FE/web-ui",
    "build:tokens": "cd ./FE/web-ui/ && style-dictionary build --config ./style-dictionary.config.js --verbose   # build .scss styles from .json tokens",
    "start": "next start FE/web-ui",
    "lint": "next lint FE/web-ui",
    "eslint --fix": "eslint FE/web-ui --fix",
    "test:unit": "jest --coverage",
    "test:e2e": "(cucumber-js e2e/features  || true) && tsx e2e/helper/report/report.ts"
  },
  "dependencies": {
    "geist": "^1.4.2",
    "next": "15.4.1",
    "non.geist": "^1.0.4",
    "pnpm": "10.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "12.1.0",
    "@eslint/eslintrc": "3",
    "@eslint/js": "9.33.0",
    "@headlessui/react": "^2.2.7",
    "@playwright/test": "1.54.1",
    "@radix-ui/react-form": "^0.1.8",
    "@radix-ui/themes": "3.2.1",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "20",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@typescript-eslint/eslint-plugin": "8.39.0",
    "@typescript-eslint/parser": "8.39.0",
    "axios": "1.11.0",
    "concurrently": "9.2.0",
    "eslint": "9",
    "eslint-config-next": "15.4.1",
    "framer-motion": "^12.23.12",
    "globals": "16.3.0",
    "jest": "30.0.4",
    "jest-environment-jsdom": "30.0.4",
    "jiti": "2.5.1",
    "lucide-react": "^0.542.0",
    "multiple-cucumber-html-reporter": "3.9.3",
    "radix-ui": "^1.4.3",
    "react-hook-form": "^7.62.0",
    "react-label": "^0.0.6",
    "sass": "^1.91.0",
    "style-dictionary": "^5.0.2",
    "ts-jest": "29.4.0",
    "ts-node": "10.9.2",
    "tsx": "4.20.3",
    "typescript": "5",
    "typescript-eslint": "8.39.0"
  }
}
